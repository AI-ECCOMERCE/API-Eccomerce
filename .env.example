# DesignAI Store — API Backend Environment
# Salin file ini ke .env dan isi dengan kredensial Supabase kamu

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
# Dapatkan dari: https://supabase.com/dashboard → Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=4000
NODE_ENV=development

# ===========================================
# CORS (Frontend URLs)
# ===========================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ===========================================
# PAKASIR PAYMENT (QRIS)
# Isi slug dan API key proyek dari dashboard Pakasir
# Webhook URL yang didaftarkan di Pakasir:
# http://localhost:4000/api/payments/pakasir/webhook
# ===========================================
PAKASIR_SLUG=your-project-slug
PAKASIR_API_KEY=your-pakasir-api-key
PAKASIR_SANDBOX_MODE=false
PAYMENT_ACCESS_SECRET=generate-a-long-random-secret
PAYMENT_ACCESS_TTL_MS=86400000

# ===========================================
# RESEND EMAIL DELIVERY
# Verifikasi domain atau subdomain milikmu di Resend terlebih dahulu.
# Rekomendasi: gunakan subdomain khusus email transaksi, mis. mail.poinstore.my.id
# Jika yang diverifikasi adalah mail.poinstore.my.id, maka sender harus memakai domain itu juga.
# Contoh:
# RESEND_FROM_EMAIL="Poinstore <noreply@mail.poinstore.my.id>"
# RESEND_REPLY_TO=support@poinstore.my.id
# reply-to opsional, bisa dikosongkan jika balasan email tidak dipakai.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_REPLY_TO=
FRONTEND_URL=http://localhost:3000
