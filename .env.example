# DesignAI Store — API Backend Environment
# Salin file ini ke .env dan isi dengan kredensial Supabase kamu

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
# Dapatkan dari: https://supabase.com/dashboard → Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=4000
NODE_ENV=development

# ===========================================
# CORS (Frontend URLs)
# ===========================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ===========================================
# PAKASIR PAYMENT (QRIS) — akan disetup nanti
# ===========================================
# PAKASIR_MERCHANT_ID=
# PAKASIR_API_KEY=
# PAKASIR_CALLBACK_URL=http://localhost:4000/api/payment/callback
